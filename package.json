{
  "name": "fialho-clean",
  "version": "1.0.0",
  "description": "Windows PC cleaner & optimizer built with Tauri 2 + Rust + React",
  "author": "Haniel Cota",
  "license": "MIT",
  "homepage": "https://github.com/HanielCota/FialhoClean#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/HanielCota/FialhoClean.git"
  },
  "bugs": {
    "url": "https://github.com/HanielCota/FialhoClean/issues"
  },
  "keywords": [
    "windows",
    "cleaner",
    "optimizer",
    "tauri",
    "rust",
    "react",
    "desktop"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "check": "biome check",
    "check:fix": "biome check --fix",
    "format": "biome format --write",
    "lint": "biome lint",
    "format:rs": "cd src-tauri && cargo fmt",
    "check:all": "biome check && cd src-tauri && cargo fmt -- --check",
    "sync-version": "node scripts/sync-version.js",
    "tauri:build": "tauri build",
    "test:rs": "cd src-tauri && cargo test"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.95.0",
    "@tauri-apps/api": "^2.10.1",
    "geist": "^1.7.0",
    "i18next": "^25.10.5",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.2",
    "sonner": "^2.0.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.2"
  }
}
